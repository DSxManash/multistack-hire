# =============================================================================
# Multistack Hire — Frontend (Vite + React)
# =============================================================================
# Copy this file to `.env` in this directory:
#
#   cp .env.example .env
#
# Only variables prefixed with VITE_ are exposed to browser code via
# import.meta.env. Restart the dev server after changing values.
# =============================================================================

# -----------------------------------------------------------------------------
# API URL (browser → backend)
# -----------------------------------------------------------------------------
# Base URL for API requests from the browser. No trailing slash.
#
# Local dev (backend on host):     http://localhost:8000
# Docker Compose (from browser): http://localhost:8000
#
# Leave empty to use relative URLs and the Vite dev proxy (see VITE_PROXY_TARGET).
VITE_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Vite dev-server proxy (Node only — not sent to the browser)
# -----------------------------------------------------------------------------
# Where Vite forwards proxied paths (e.g. /health) during `npm run dev`.
# Set in docker-compose for the frontend service; optional in a local .env.
#
# Local dev (backend on host):  http://localhost:8000
# Docker Compose (in-network):  http://backend:8000
#
# VITE_PROXY_TARGET=http://localhost:8000
