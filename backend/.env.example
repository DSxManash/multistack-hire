# =============================================================================
# Multistack Hire — Backend (FastAPI)
# =============================================================================
# Copy this file to `.env` in this directory:
#
#   cp .env.example .env
#
# docker-compose.yml loads backend/.env via `env_file`. For local runs without
# Docker, python-dotenv will load this file once config is wired in app/core.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
APP_NAME=Multistack Hire API

# -----------------------------------------------------------------------------
# Database (PostgreSQL + asyncpg)
# -----------------------------------------------------------------------------
# SQLAlchemy async URL format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB
#
# Local dev (Postgres on host):  postgresql+asyncpg://user:pass@localhost:5432/dbname
# Docker Compose (db service):   postgresql+asyncpg://user:pass@db:5432/dbname
#
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/dbname

# -----------------------------------------------------------------------------
# Security / JWT
# -----------------------------------------------------------------------------
# Generate a secret: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated origins allowed to call the API from the browser.
# Do not use * in production when allow_credentials is enabled.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# External integrations (optional)
# -----------------------------------------------------------------------------
# Improves GitHub API rate limits when fetching candidate profiles.
GITHUB_TOKEN=

# Stack Exchange / StackOverflow API key (optional).
STACKOVERFLOW_API_KEY=

# -----------------------------------------------------------------------------
# Machine learning (optional)
# -----------------------------------------------------------------------------
# Directory for trained XGBoost model artifacts and SHAP explainers.
MODEL_PATH=./models
MODEL_VERSION=latest
